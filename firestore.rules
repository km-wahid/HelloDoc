rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Validation Blueprint
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt', 'updatedAt'])
        && data.keys().size() == 6
        && data.uid is string && data.uid == request.auth.uid
        && data.email is string && data.email == request.auth.token.email
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.role in ['patient', 'doctor', 'worker']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming());
      
      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().updatedAt == request.time
        && incoming().uid == existing().uid
        && incoming().role == existing().role
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']);
    }

    // Assessment Rules
    function isValidAssessment(data) {
      return data.keys().hasAll(['userId', 'status', 'data', 'createdAt'])
        && data.userId == request.auth.uid
        && data.status in ['pending', 'completed']
        && data.createdAt == request.time;
    }

    match /assessments/{assessmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && isValidAssessment(incoming());

      // Updates only for marking as completed with report
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasAll(['report', 'status'])
        && incoming().status == 'completed';
      
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
